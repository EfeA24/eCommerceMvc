<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-3">
        <div class="container-fluid">
            <a class="navbar-brand" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Admin</a>
            <div class="navbar-nav">
                <a class="nav-link" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                <a class="nav-link" asp-area="Admin" asp-controller="Stores" asp-action="Index">Stores</a>
                <a class="nav-link" asp-area="Admin" asp-controller="Products" asp-action="Index">Products</a>
                <a class="nav-link" asp-area="Admin" asp-controller="SyncCenter" asp-action="Index">Sync Center</a>
                <a class="nav-link" asp-area="Admin" asp-controller="PageBuilder" asp-action="Index">Page Builder</a>
            </div>
        </div>
    </nav>
    <main class="container pb-4">
        @RenderBody()
    </main>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
